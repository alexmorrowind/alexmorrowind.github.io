# Copy this file to `.env` in the same folder as `manage.py`.
# Never commit `.env` to GitHub.

# Django
DJANGO_SECRET_KEY=change-me-for-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8765,http://localhost:8765

# Public URLs
# For local test:
FRONTEND_PUBLIC_URL=http://127.0.0.1:8765/index.html
BACKEND_PUBLIC_URL=http://127.0.0.1:8000

# Payme Merchant API: checkout, orders, investments, reports.
# In Payme cabinet:
# - "Ключ" is production key.
# - "Тестовый ключ" is test key.
# For testing, paste TEST key into PAYME_MERCHANT_KEY.
PAYME_MERCHANT_ID=your_payme_merchant_or_cashbox_id
PAYME_MERCHANT_KEY=paste_test_key_here
PAYME_CHECKOUT_URL=https://checkout.test.paycom.uz
PAYME_CALLBACK_URL=http://127.0.0.1:8765/index.html

# Payme Subscribe API: add card, SMS verify, tokenized card payments.
# These are separate credentials from Merchant API in many Payme accounts.
PAYME_SUBSCRIBE_BASE_URL=https://checkout.test.paycom.uz/api
PAYME_SUBSCRIBE_ID=your_payme_subscribe_id
PAYME_SUBSCRIBE_KEY=your_payme_subscribe_key_or_password

# MyID
# Leave empty for demo mode. Fill after MyID gives your credentials.
MYID_BASE_URL=
MYID_CLIENT_ID=
MYID_USERNAME=
MYID_PASSWORD=
MYID_HOSTED_URL=

# Registration SMS
# Leave demo mode enabled until a real SMS provider is connected.
SMS_DEMO_MODE=true
SMS_DEMO_CODE=666666
SMS_PROVIDER_URL=
SMS_PROVIDER_TOKEN=
